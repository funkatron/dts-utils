<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>dts-util — generate</title>
  <style>
    :root {
      --bg: #1a1b1e;
      --fg: #e8e6e3;
      --muted: #9b9898;
      --accent: #4a9eff;
      --ok: #5a9a6e;
      --bad: #c45c5c;
      --border: #3a3d45;
      --panel: #222328;
    }
    * { box-sizing: border-box; }
    html, body { height: 100%; margin: 0; }
    body {
      font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
      background: var(--bg);
      color: var(--fg);
      line-height: 1.45;
      display: flex;
      flex-direction: column;
      min-height: 100vh;
      min-height: 100dvh;
      overflow: hidden;
    }
    /* Minimal top bar: identity + setup */
    .shell-top {
      flex: 0 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      padding: 0.35rem 0.65rem;
      border-bottom: 1px solid var(--border);
      font-size: 0.75rem;
      color: var(--muted);
    }
    .app-mark { font-weight: 600; letter-spacing: 0.02em; }
    button.btn-setup {
      background: transparent;
      color: var(--accent);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 0.35rem 0.65rem;
      font: inherit;
      font-size: 0.8rem;
      cursor: pointer;
    }
    button.btn-setup:hover { border-color: var(--muted); }
    /* Image dominates remaining space */
    #stage {
      flex: 1 1 auto;
      min-height: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0.25rem;
      overflow: auto;
    }
    #resultPane {
      width: 100%;
      height: 100%;
      min-height: 12rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
    }
    .result-placeholder {
      font-size: 0.9rem;
      color: var(--muted);
      text-align: center;
      margin: 0;
      padding: 1rem;
      max-width: 22rem;
    }
    .result-busy {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      font-size: 0.9rem;
      color: var(--muted);
    }
    .result-busy[hidden] { display: none !important; }
    .spinner {
      width: 1.25rem;
      height: 1.25rem;
      border: 2px solid var(--border);
      border-top-color: var(--accent);
      border-radius: 50%;
      animation: dts-spin 0.65s linear infinite;
      flex-shrink: 0;
    }
    @keyframes dts-spin { to { transform: rotate(360deg); } }
    @media (prefers-reduced-motion: reduce) {
      .spinner { animation: none; border-top-color: var(--border); }
    }
    .results {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      width: 100%;
      flex: 1 1 auto;
      min-height: 0;
    }
    .results > div {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.35rem;
      max-width: 100%;
      max-height: 100%;
    }
    .results img {
      display: block;
      max-width: 100%;
      max-height: min(85vh, calc(100dvh - 9rem));
      width: auto;
      height: auto;
      object-fit: contain;
      border-radius: 4px;
      border: 1px solid var(--border);
    }
    /* Error strip — thin, above composer */
    #err {
      flex: 0 0 auto;
      display: none;
      padding: 0.35rem 0.65rem;
      font-size: 0.8rem;
      color: var(--bad);
      background: rgba(196, 92, 92, 0.12);
      border-top: 1px solid var(--border);
    }
    /* Bottom composer: prompt + generate only */
    .composer {
      flex: 0 0 auto;
      display: flex;
      align-items: flex-end;
      gap: 0.5rem;
      padding: 0.5rem 0.65rem 0.65rem;
      border-top: 1px solid var(--border);
      background: var(--bg);
    }
    .composer-prompt {
      flex: 1 1 auto;
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }
    .composer-prompt label {
      font-size: 0.7rem;
      color: var(--muted);
      margin: 0;
    }
    textarea#prompt {
      width: 100%;
      min-height: 2.75rem;
      max-height: min(40vh, 12rem);
      resize: vertical;
      font-size: 1rem;
      line-height: 1.35;
      background: #25262b;
      border: 1px solid var(--border);
      color: var(--fg);
      border-radius: 4px;
      padding: 0.45rem 0.55rem;
      font: inherit;
    }
    .composer-actions {
      flex: 0 0 auto;
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 0.25rem;
    }
    #btnGen {
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 4px;
      padding: 0.55rem 1rem;
      font: inherit;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
    }
    #btnGen:disabled { opacity: 0.45; cursor: not-allowed; }
    #elapsed {
      font-size: 0.7rem;
      color: var(--muted);
      text-align: center;
      min-height: 1em;
    }
    /* Setup dialog */
    dialog.tools-dialog {
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 0;
      background: var(--panel);
      color: var(--fg);
      max-width: 26rem;
      width: calc(100vw - 2rem);
      max-height: min(85vh, 640px);
    }
    dialog.tools-dialog::backdrop {
      background: rgba(0, 0, 0, 0.55);
    }
    .tools-dialog-inner {
      padding: 1rem;
      overflow-y: auto;
      max-height: min(78vh, 580px);
    }
    .tools-dialog h2 {
      margin: 0 0 0.75rem;
      font-size: 1rem;
      font-weight: 600;
      color: var(--fg);
    }
    label { color: var(--muted); font-size: 0.8rem; }
    input[type="text"], input[type="number"], select, textarea.field {
      background: #25262b;
      border: 1px solid var(--border);
      color: var(--fg);
      border-radius: 4px;
      padding: 0.35rem 0.5rem;
      font: inherit;
    }
    .tools-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem 1rem;
      align-items: flex-end;
      margin-bottom: 0.65rem;
    }
    .tools-row > div { flex: 0 0 auto; }
    button.btn-secondary {
      background: transparent;
      color: var(--accent);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 0.35rem 0.65rem;
      font: inherit;
      font-size: 0.85rem;
      cursor: pointer;
    }
    .status { font-size: 0.85rem; margin: 0.35rem 0; }
    .status.ok { color: var(--ok); }
    .status.bad { color: var(--bad); }
    .hint { font-size: 0.75rem; color: var(--muted); margin: 0 0 0.75rem; }
    details.advanced { margin-top: 0.75rem; font-size: 0.85rem; }
    details.advanced summary { cursor: pointer; color: var(--muted); }
    .tools-footer {
      margin-top: 1rem;
      padding-top: 0.75rem;
      border-top: 1px solid var(--border);
      font-size: 0.75rem;
      color: var(--muted);
    }
    .tools-footer a { color: var(--accent); }
    .dialog-close-row {
      padding: 0.65rem 1rem;
      border-top: 1px solid var(--border);
      display: flex;
      justify-content: flex-end;
      background: var(--bg);
    }
    .dialog-close-row button {
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 4px;
      padding: 0.45rem 1rem;
      font: inherit;
      cursor: pointer;
    }
    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  </style>
</head>
<body>
  <header class="shell-top">
    <span class="app-mark">dts-util web</span>
    <button type="button" class="btn-setup" id="btnOpenSetup" aria-haspopup="dialog" aria-controls="toolsDialog" aria-expanded="false">
      Setup
    </button>
  </header>

  <div id="stage" role="region" aria-label="Generated image">
    <div id="resultPane" aria-live="polite">
      <p id="resultPlaceholder" class="result-placeholder">
        Generated image fills this space. Write a prompt below and press Generate.
      </p>
      <div id="resultBusy" class="result-busy" hidden>
        <span class="spinner" aria-hidden="true"></span>
        <span class="sr-only">Generating</span>
        <span id="busyElapsed" class="hint"></span>
      </div>
      <div id="results" class="results"></div>
    </div>
  </div>

  <div id="err" class="status bad" role="alert"></div>

  <footer class="composer">
    <div class="composer-prompt">
      <label for="prompt">Prompt</label>
      <textarea id="prompt" autofocus placeholder="Describe the image…" autocomplete="off" rows="2"></textarea>
    </div>
    <div class="composer-actions">
      <button type="button" id="btnGen">Generate</button>
      <span id="elapsed" class="hint"></span>
    </div>
  </footer>

  <dialog id="toolsDialog" class="tools-dialog" aria-labelledby="tools-dialog-title">
    <div class="tools-dialog-inner">
      <h2 id="tools-dialog-title">Connection &amp; profile</h2>

      <section aria-label="gRPC connection">
        <div class="tools-row">
          <div>
            <label for="host">Host</label><br/>
            <input id="host" type="text" value="localhost" size="14" autocomplete="off" />
          </div>
          <div>
            <label for="port">gRPC port</label><br/>
            <input id="port" type="number" value="7859" style="width:4.5rem" />
          </div>
          <div>
            <label><input type="checkbox" id="noTls" /> no-TLS</label>
          </div>
          <div>
            <label><input type="checkbox" id="trustCert" checked /> trust loopback</label>
          </div>
          <button type="button" class="btn-secondary" id="btnCheck">Check listener</button>
        </div>
        <div id="statusLine" class="status" role="status" aria-live="polite">Not checked yet.</div>
        <p class="hint">Probe only (listener). Generation can still fail (config, flatc, model, TLS).</p>
      </section>

      <section aria-label="Profile">
        <label for="profile">Saved JSON profile</label><br/>
        <select id="profile"></select>
        <input id="profileCustom" type="text" placeholder="Or custom name/path…" style="margin-top:0.35rem;width:100%" autocomplete="off" class="field" />
      </section>

      <details class="advanced">
        <summary>Negative prompt, secret, TLS paths</summary>
        <div style="margin-top:0.6rem">
          <label for="neg">Negative prompt</label>
          <textarea id="neg" class="field" style="min-height:3rem;width:100%;margin-top:0.25rem"></textarea>
        </div>
        <div class="tools-row" style="margin-top:0.5rem">
          <div style="flex:1;min-width:12rem">
            <label for="sharedSecret">Shared secret</label><br/>
            <input id="sharedSecret" type="text" style="width:100%" autocomplete="off" class="field" />
          </div>
          <div style="flex:1;min-width:12rem">
            <label for="rootCert">Root cert path</label><br/>
            <input id="rootCert" type="text" style="width:100%" autocomplete="off" class="field" />
          </div>
        </div>
        <div style="margin-top:0.5rem">
          <label><input type="checkbox" id="forceTrust" /> force-trust server cert (MITM risk)</label>
        </div>
        <div style="margin-top:0.5rem">
          <label for="configDir">Config directory override</label><br/>
          <input id="configDir" type="text" style="width:100%" placeholder="Default: dts-util configs path" autocomplete="off" class="field" />
        </div>
      </details>

      <div class="tools-footer">
        <p><a href="https://github.com/funkatron/dts-utils/blob/main/CLI.md" target="_blank" rel="noopener">CLI reference</a></p>
        <details>
          <summary>Server not installed?</summary>
          <pre style="white-space:pre-wrap;background:#25262b;padding:0.5rem;border-radius:4px;border:1px solid var(--border);font-size:0.72rem;margin-top:0.35rem">uv run dts-util server install
uv run dts-util server check</pre>
        </details>
      </div>
    </div>
    <div class="dialog-close-row">
      <button type="button" id="btnCloseSetup">Done</button>
    </div>
  </dialog>

  <script>
  window.__DTS_INIT__ = { token: {{ (api_token or none)|tojson }} };

  function authHeaders(base) {
    const h = Object.assign({}, base || {});
    if (window.__DTS_INIT__.token)
      h["Authorization"] = "Bearer " + window.__DTS_INIT__.token;
    return h;
  }

  function indexOfU8(hay, needle, start) {
    start = start | 0;
    outer: for (let i = start; i <= hay.length - needle.length; i++) {
      for (let j = 0; j < needle.length; j++)
        if (hay[i + j] !== needle[j]) continue outer;
      return i;
    }
    return -1;
  }

  function parseMultipartPngs(arrayBuffer, contentType) {
    const ct = contentType || "";
    const m = /boundary=([\w'./+:-]+)/i.exec(ct);
    if (!m) throw new Error("No multipart boundary in Content-Type");
    const boundary = m[1].trim().replace(/^["']|["']$/g, "");
    const u8 = new Uint8Array(arrayBuffer);
    const enc = new TextEncoder();
    const dec = new TextDecoder("latin1");
    const sep = enc.encode("\r\n--" + boundary);
    const preamble = enc.encode("--" + boundary);
    const parts = [];
    let idx = indexOfU8(u8, preamble, 0);
    while (idx !== -1) {
      idx += 2 + boundary.length;
      if (idx + 1 < u8.length && u8[idx] === 45 && u8[idx + 1] === 45) break;
      if (idx + 1 < u8.length && u8[idx] === 13 && u8[idx + 1] === 10) idx += 2;
      const hdrEnd = indexOfU8(u8, enc.encode("\r\n\r\n"), idx);
      if (hdrEnd === -1) break;
      const headers = dec.decode(u8.subarray(idx, hdrEnd));
      const bodyStart = hdrEnd + 4;
      const nextSep = indexOfU8(u8, sep, bodyStart);
      if (nextSep === -1) break;
      if (headers.toLowerCase().includes("content-type: image/png"))
        parts.push(arrayBuffer.slice(bodyStart, nextSep));
      idx = nextSep;
    }
    return parts;
  }

  function formatListenerLine(j) {
    const probe = j.probe ? " (" + j.probe + ")" : "";
    if (j.listener_ok)
      return { text: "Listener OK — " + (j.message || "") + probe, ok: true };
    return { text: "Unreachable — " + (j.message || "") + probe, ok: false };
  }

  async function refreshStatus() {
    const host = document.getElementById("host").value.trim() || "localhost";
    const port = document.getElementById("port").value || "7859";
    const noTls = document.getElementById("noTls").checked;
    const el = document.getElementById("statusLine");
    el.textContent = "Checking…";
    el.className = "status";
    const q = new URLSearchParams({ host, port, no_tls: noTls ? "true" : "false" });
    const r = await fetch("/api/server-status?" + q.toString(), { headers: authHeaders() });
    if (r.status === 401) {
      el.textContent = "Unauthorized — set DTS_WEB_TOKEN and reload.";
      el.className = "status bad";
      return;
    }
    const j = await r.json();
    if (!r.ok) {
      el.textContent = j.detail || "Error";
      el.className = "status bad";
      return;
    }
    const fmt = formatListenerLine(j);
    el.textContent = fmt.text;
    el.className = "status " + (fmt.ok ? "ok" : "bad");
  }

  async function loadConfigs() {
    const sel = document.getElementById("profile");
    sel.innerHTML = "";
    try {
      const r = await fetch("/api/configs", { headers: authHeaders() });
      if (r.status === 401) {
        const o = document.createElement("option");
        o.value = "zit";
        o.textContent = "zit (set DTS_WEB_TOKEN to list profiles)";
        o.selected = true;
        sel.appendChild(o);
        return;
      }
      const j = await r.json();
      if (!r.ok) return;
      const defaultProfile = j.default_profile || "zit";
      const names = [...new Set([...(j.names || []), defaultProfile])].sort();
      for (const n of names) {
        const o = document.createElement("option");
        o.value = n;
        o.textContent = n;
        if (n === defaultProfile) o.selected = true;
        sel.appendChild(o);
      }
    } catch (e) {
      console.error("loadConfigs:", e);
      const o = document.createElement("option");
      o.value = "zit";
      o.textContent = "zit";
      o.selected = true;
      sel.appendChild(o);
    }
  }

  function effectiveProfile() {
    const c = document.getElementById("profileCustom").value.trim();
    if (c) return c;
    return document.getElementById("profile").value || "zit";
  }

  function connectionPayload() {
    const host = document.getElementById("host").value.trim() || "localhost";
    const port = parseInt(document.getElementById("port").value, 10) || 7859;
    const noTls = document.getElementById("noTls").checked;
    const trust = document.getElementById("trustCert").checked;
    const force = document.getElementById("forceTrust").checked;
    const rootCert = document.getElementById("rootCert").value.trim();
    const configDir = document.getElementById("configDir").value.trim();
    const body = { host, port, no_tls: noTls, trust_server_cert: trust, force_trust_server_cert: force };
    if (rootCert) body.root_cert = rootCert;
    if (configDir) body.config_dir = configDir;
    return body;
  }

  function prefersReducedMotion() {
    return window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  }

  function setGeneratingUi(active, t0, timerRef) {
    const placeholder = document.getElementById("resultPlaceholder");
    const busy = document.getElementById("resultBusy");
    const busyElapsed = document.getElementById("busyElapsed");
    const pane = document.getElementById("resultPane");
    if (active) {
      placeholder.hidden = true;
      busy.hidden = false;
      busyElapsed.textContent = prefersReducedMotion() ? "Generating…" : "0.0s";
      pane.setAttribute("aria-busy", "true");
      if (timerRef.id) clearInterval(timerRef.id);
      timerRef.id = setInterval(function () {
        if (prefersReducedMotion()) return;
        busyElapsed.textContent = ((performance.now() - t0) / 1000).toFixed(1) + "s";
      }, 100);
    } else {
      if (timerRef.id) {
        clearInterval(timerRef.id);
        timerRef.id = null;
      }
      busy.hidden = true;
      pane.removeAttribute("aria-busy");
    }
  }

  async function runGenerate() {
    const errEl = document.getElementById("err");
    const results = document.getElementById("results");
    const placeholder = document.getElementById("resultPlaceholder");
    const elapsed = document.getElementById("elapsed");
    const timerRef = { id: null };
    errEl.style.display = "none";
    results.innerHTML = "";
    const btn = document.getElementById("btnGen");
    btn.disabled = true;
    const t0 = performance.now();
    elapsed.textContent = "";

    const prompt = document.getElementById("prompt").value.trim();
    if (!prompt) {
      errEl.textContent = "Enter a prompt.";
      errEl.style.display = "block";
      placeholder.hidden = false;
      btn.disabled = false;
      return;
    }

    setGeneratingUi(true, t0, timerRef);

    const shared = document.getElementById("sharedSecret").value.trim();
    const neg = document.getElementById("neg").value;
    const body = Object.assign(connectionPayload(), {
      prompt,
      negative_prompt: neg,
      configuration: effectiveProfile(),
    });
    if (shared) body.shared_secret = shared;

    try {
      const r = await fetch("/api/generate", {
        method: "POST",
        headers: authHeaders({ "Content-Type": "application/json", "Accept": "multipart/mixed,*/*" }),
        body: JSON.stringify(body),
      });
      const dt = ((performance.now() - t0) / 1000).toFixed(1);
      elapsed.textContent = r.ok ? ("Done in " + dt + "s") : "";

      if (r.status === 401) {
        errEl.textContent = "Unauthorized — set DTS_WEB_TOKEN and reload.";
        errEl.style.display = "block";
        placeholder.hidden = false;
        return;
      }

      const ct = r.headers.get("content-type") || "";
      if (!r.ok) {
        let msg = r.statusText;
        try {
          const j = await r.json();
          msg = j.detail || msg;
        } catch (_) {}
        errEl.textContent = msg;
        errEl.style.display = "block";
        placeholder.hidden = false;
        return;
      }

      if (ct.includes("multipart/mixed")) {
        const buf = await r.arrayBuffer();
        const blobs = parseMultipartPngs(buf, ct);
        placeholder.hidden = true;
        blobs.forEach((b, i) => {
          const url = URL.createObjectURL(new Blob([b], { type: "image/png" }));
          const img = document.createElement("img");
          img.src = url;
          img.alt = "Generated " + (i + 1);
          const wrap = document.createElement("div");
          const a = document.createElement("a");
          a.href = url;
          a.download = "generated_" + i + ".png";
          a.textContent = "Download";
          a.style.color = "var(--accent)";
          wrap.appendChild(img);
          wrap.appendChild(document.createElement("br"));
          wrap.appendChild(a);
          results.appendChild(wrap);
        });
      } else {
        errEl.textContent = "Unexpected response " + ct;
        errEl.style.display = "block";
        placeholder.hidden = false;
      }
    } catch (e) {
      errEl.textContent = String(e);
      errEl.style.display = "block";
      placeholder.hidden = false;
    } finally {
      setGeneratingUi(false, t0, timerRef);
      btn.disabled = false;
    }
  }

  (function setupDialog() {
    const dlg = document.getElementById("toolsDialog");
    const openBtn = document.getElementById("btnOpenSetup");
    const closeBtn = document.getElementById("btnCloseSetup");
    openBtn.addEventListener("click", function () {
      if (typeof dlg.showModal === "function")
        dlg.showModal();
      openBtn.setAttribute("aria-expanded", "true");
    });
    closeBtn.addEventListener("click", function () {
      dlg.close();
    });
    dlg.addEventListener("close", function () {
      openBtn.setAttribute("aria-expanded", "false");
      openBtn.focus();
    });
  })();

  document.getElementById("btnCheck").addEventListener("click", refreshStatus);
  document.getElementById("btnGen").addEventListener("click", runGenerate);
  loadConfigs().then(function () { refreshStatus(); });
  </script>
</body>
</html>
