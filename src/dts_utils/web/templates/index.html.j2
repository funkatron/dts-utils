      actions.appendChild(reuse);
      row.appendChild(actions);
      root.appendChild(row);
    });
  }

  function prefersReducedMotion() {
    return window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  }

  /** Parse newline-delimited SSE (data: …\\n\\n) from a fetch Response body. */
  function readSSEStream(response, onEvent) {
    return new Promise(function (resolve, reject) {
      if (!response.body || !response.body.getReader) {
        reject(new Error("Streaming response body not supported in this browser."));
        return;
      }
      const reader = response.body.getReader();
      const dec = new TextDecoder();
      let buf = "";
      function pump() {
        reader
          .read()
          .then(function (res) {
            if (res.done) {
              resolve();
              return;
            }
            buf += dec.decode(res.value, { stream: true });
            let sep;
            while ((sep = buf.indexOf("\n\n")) !== -1) {
              const block = buf.slice(0, sep);
              buf = buf.slice(sep + 2);
              const lines = block.split("\n");
              for (let li = 0; li < lines.length; li++) {
                const line = lines[li];
                if (line.indexOf("data:") !== 0) continue;
                const raw = line.slice(5).trim();
                if (!raw) continue;
                let msg;
                try {
                  msg = JSON.parse(raw);
                } catch (e) {
                  reject(new Error("Invalid event data from server."));
                  return;
                }
                if (msg.type === "error") {
                  reject(new Error(msg.detail || "Generation failed."));
                  return;
                }
                try {
                  onEvent(msg);
                } catch (e) {
                  reject(e);
                  return;
                }
              }
            }
            pump();
          })
          .catch(reject);
      }
      pump();
    });
  }

  function setGeneratingUi(active, t0, timerRef, requestJsonText) {
    const placeholder = document.getElementById("resultPlaceholder");
    const busy = document.getElementById("resultBusy");
    const busyElapsed = document.getElementById("busyElapsed");
    const busyJson = document.getElementById("busyRequestJson");
    const pane = document.getElementById("resultPane");
    if (active) {
      placeholder.hidden = true;
      busy.hidden = false;
      busyElapsed.textContent = prefersReducedMotion() ? "Generating…" : "0.0s";
      var bp = document.getElementById("busyProgress");
      if (bp) bp.textContent = "";
      if (busyJson) busyJson.textContent = typeof requestJsonText === "string" ? requestJsonText : "";
      pane.setAttribute("aria-busy", "true");
      if (timerRef.id) clearInterval(timerRef.id);
      timerRef.id = setInterval(function () {
        if (prefersReducedMotion()) return;
        busyElapsed.textContent = ((performance.now() - t0) / 1000).toFixed(1) + "s";
      }, 100);
    } else {
      if (timerRef.id) {
        clearInterval(timerRef.id);
        timerRef.id = null;
      }
      busy.hidden = true;
      if (busyJson) busyJson.textContent = "";
      var bpOff = document.getElementById("busyProgress");
      if (bpOff) bpOff.textContent = "";
      pane.removeAttribute("aria-busy");
    }
  }

  var generateAbortController = null;
  var generationInFlight = false;

  async function runPromptToVideoStream(ac, t0, timerRef, body) {
    const errEl = document.getElementById("err");
    const results = document.getElementById("results");
    const placeholder = document.getElementById("resultPlaceholder");
    const elapsed = document.getElementById("elapsed");

    const r = await fetch("/api/generate/stream", {
      method: "POST",
      headers: authHeaders({
        "Content-Type": "application/json",
        Accept: "text/event-stream",
      }),
      body: JSON.stringify(body),
      signal: ac.signal,
    });

    if (r.status === 401) {
      errEl.textContent = "Unauthorized — set DTS_WEB_TOKEN and reload.";
      errEl.style.display = "block";
      placeholder.hidden = false;
      return;
    }
    if (!r.ok) {
      let msg = r.statusText;
      try {
        const j = await r.json();
        msg = j.detail || msg;
      } catch (_) {}
      errEl.textContent = msg;
      errEl.style.display = "block";
      placeholder.hidden = false;
      return;
    }

    let artifactCount = 0;
    await readSSEStream(r, async function (msg) {
      if (msg.type === "meta") {
        const prog = document.getElementById("busyProgress");
        if (prog) prog.textContent = msg.profile + " · run " + msg.run_id;
      }
      if (msg.type === "progress" && msg.message) {
        const prog = document.getElementById("busyProgress");
        if (prog) prog.textContent = msg.message;
      }
      if (msg.type === "artifact" && msg.url) {
        placeholder.hidden = true;
        const ar = await fetch(msg.url, { headers: authHeaders() });
        if (!ar.ok) return;
        const blob = await ar.blob();
        const url = URL.createObjectURL(blob);
        __dtsResultBlobUrls.push(url);
        const wrap = document.createElement("div");
        wrap.className = "result-slot";
        if (msg.kind === "video") {
          const vid = document.createElement("video");
          vid.src = url;
          vid.controls = true;
          vid.className = "result-inflight";
          wrap.appendChild(vid);
        } else {
          const img = document.createElement("img");
          img.src = url;
          img.alt = msg.step_id + " " + msg.filename;
          img.className = "result-inflight";
          wrap.appendChild(img);
        }
        const a = document.createElement("a");
        a.href = url;
        a.download = msg.filename || "artifact";
        a.textContent = "Download";
        a.className = "result-download";
        wrap.appendChild(a);
        results.appendChild(wrap);
        artifactCount += 1;
      }
      if (msg.type === "error") {
        errEl.textContent = msg.detail || "Generate failed.";
        errEl.style.display = "block";
      }
    });

    elapsed.textContent = "Done in " + ((performance.now() - t0) / 1000).toFixed(1) + "s";
    results.querySelectorAll(".result-inflight").forEach(function (el) {
      el.classList.remove("result-inflight");
    });
    placeholder.hidden = artifactCount > 0;
  }

  async function runComposerAction() {
    await runGenerate();
  }

  async function runGenerate() {
    if (generationInFlight) return;
    const errEl = document.getElementById("err");
    const results = document.getElementById("results");
    const placeholder = document.getElementById("resultPlaceholder");
    const elapsed = document.getElementById("elapsed");
    const splitEl = document.querySelector(".split-run-gen");
    const btnGen = document.getElementById("btnGen");
    const timerRef = { id: null };
    errEl.style.display = "none";
    revokeResultBlobUrls();
    results.innerHTML = "";
    var expNoteClear = document.getElementById("expandedPromptsNote");
    if (expNoteClear) {
      expNoteClear.hidden = true;
      expNoteClear.replaceChildren();
    }
    btnGen.disabled = true;
    const t0 = performance.now();
    elapsed.textContent = "";

    const prompt = document.getElementById("prompt").value.trim();
    if (!prompt) {
      errEl.textContent = "Enter a prompt.";
      errEl.style.display = "block";
      placeholder.hidden = false;
      btnGen.disabled = false;
      return;
    }

    generationInFlight = true;
    const ac = new AbortController();
    generateAbortController = ac;
    splitEl.classList.add("is-busy");
    var runsEl = document.getElementById("generations");

    if (isVideoProfileMode()) {
      runsEl.disabled = true;
      const body = buildVideoGenerateBody();
      setGeneratingUi(true, t0, timerRef, JSON.stringify(body, null, 2));
      try {
        await runPromptToVideoStream(ac, t0, timerRef, body);
      } catch (e) {
        if (e.name === "AbortError") {
          elapsed.textContent = "Stopped";
          placeholder.hidden = false;
        } else {
          errEl.textContent = String(e);
          errEl.style.display = "block";
          placeholder.hidden = false;
        }
      } finally {
        splitEl.classList.remove("is-busy");
        generateAbortController = null;
        generationInFlight = false;
        setGeneratingUi(false, t0, timerRef);
        btnGen.disabled = false;
      }
      return;
    }

    runsEl.disabled = false;
    var generations = parseInt(runsEl.value, 10);
    if (!Number.isFinite(generations) || generations < 1) generations = 1;
    if (generations > 25) generations = 25;

    setGeneratingUi(true, t0, timerRef, "");

    try {
      const expandRes = await fetch("/api/prompt/expand", {
        method: "POST",
        headers: authHeaders({ "Content-Type": "application/json" }),
        body: JSON.stringify({
          prompt,
          negative_prompt: document.getElementById("neg").value,
          count: generations,
        }),
        signal: ac.signal,
      });

      if (expandRes.status === 401) {
        errEl.textContent = "Unauthorized — set DTS_WEB_TOKEN and reload.";
        errEl.style.display = "block";
        placeholder.hidden = false;
        return;
      }

      if (!expandRes.ok) {
        let msg = expandRes.statusText;
        try {
          const ej = await expandRes.json();
          msg = ej.detail || msg;
        } catch (_) {}
        errEl.textContent = msg;
        errEl.style.display = "block";
        placeholder.hidden = false;
        return;
      }

      const expanded = await expandRes.json();
      const body = buildResolvedGenerateBody(expanded, generations);
      const payloadPreview = formatGenerateBodyForDisplay(body);
      setGeneratingUi(true, t0, timerRef, payloadPreview);

      const r = await fetch("/api/generate/stream", {
        method: "POST",
        headers: authHeaders({
          "Content-Type": "application/json",
          Accept: "text/event-stream",
        }),
        body: JSON.stringify(body),
        signal: ac.signal,
      });

      if (r.status === 401) {
        errEl.textContent = "Unauthorized — set DTS_WEB_TOKEN and reload.";
        errEl.style.display = "block";
        placeholder.hidden = false;
        return;
      }

      if (!r.ok) {
        let msg = r.statusText;
        try {
          const j = await r.json();
          msg = j.detail || msg;
        } catch (_) {}
        errEl.textContent = msg;
        errEl.style.display = "block";
        placeholder.hidden = false;
        return;
      }

      const ct = r.headers.get("content-type") || "";
      if (!ct.includes("text/event-stream")) {
        errEl.textContent = "Expected text/event-stream from server, got: " + ct;
        errEl.style.display = "block";
        placeholder.hidden = false;
        return;
      }

      const historyBuffers = [];
      let donePayload = null;
      await readSSEStream(r, function (msg) {
        if (msg.type === "meta") {
          var prog = document.getElementById("busyProgress");
          if (prog) prog.textContent = "Starting · " + msg.total_runs + " run(s)";
        }
        if (msg.type === "progress") {
          var prog = document.getElementById("busyProgress");
          if (prog) prog.textContent = "Run " + msg.run + " / " + msg.total_runs + " — contacting Draw Things…";
        }
        if (msg.type === "image") {
          placeholder.hidden = true;
          var bin = atob(msg.png_b64);
          var bytes = new Uint8Array(bin.length);
          for (var j = 0; j < bin.length; j++) bytes[j] = bin.charCodeAt(j);
          historyBuffers.push(bytes.buffer.slice(bytes.byteOffset, bytes.byteOffset + bytes.byteLength));
          var blob = new Blob([bytes], { type: "image/png" });
          var url = URL.createObjectURL(blob);
          __dtsResultBlobUrls.push(url);
          var img = document.createElement("img");
          img.src = url;
          img.alt = "Generated " + msg.index + " (run " + msg.run + ")";
          img.className = "result-inflight";
          var wrap = document.createElement("div");
          wrap.className = "result-slot";
          var a = document.createElement("a");
          a.href = url;
          a.download = "generated_" + msg.index + ".png";
          a.textContent = "Download";
          a.className = "result-download";
          wrap.appendChild(img);
          wrap.appendChild(a);
          results.appendChild(wrap);
          var prog2 = document.getElementById("busyProgress");
          if (prog2)
            prog2.textContent =
              "Run " + msg.run + " / " + msg.total_runs + " · received image " + msg.index;
        }
        if (msg.type === "done") {
          donePayload = msg;
        }
      });

      const dt = ((performance.now() - t0) / 1000).toFixed(1);
      elapsed.textContent = "Done in " + dt + "s";

      results.querySelectorAll("img.result-inflight").forEach(function (im) {
        im.classList.remove("result-inflight");
      });

      if (historyBuffers.length) {
        await historyAppend(
          prompt,
          document.getElementById("neg").value,
          generations,
          historyBuffers,
          body.configuration,
        );
      }

      var expNote = document.getElementById("expandedPromptsNote");
      if (expNote && donePayload && donePayload.expanded_prompts && donePayload.expanded_prompts.length) {
        expNote.hidden = false;
        renderExpandedPromptsPanel(
          expNote,
          donePayload.expanded_prompts,
          donePayload.expanded_negative_prompts || [],
        );
      } else if (expNote) {
        expNote.hidden = true;
        expNote.replaceChildren();
      }

      placeholder.hidden = historyBuffers.length > 0;
    } catch (e) {
      if (e.name === "AbortError") {
        requestGenerationCancel();
        errEl.style.display = "none";
        elapsed.textContent = "Stopped";
        placeholder.hidden = false;
      } else {
        errEl.textContent = String(e);
        errEl.style.display = "block";
        placeholder.hidden = false;
      }
    } finally {
      splitEl.classList.remove("is-busy");
      runsEl.disabled = false;
      generateAbortController = null;
      generationInFlight = false;
      setGeneratingUi(false, t0, timerRef);
      btnGen.disabled = false;
    }
  }

  var __dtsLightboxState = { urls: [], index: 0, onKey: null, touchX: null, fitFill: false };

  function syncLightboxFitFillUi() {
    var stage = document.getElementById("dtsLightboxStage");
    if (stage) {
      if (__dtsLightboxState.fitFill) stage.classList.add("dts-lightbox-stage--fill");
      else stage.classList.remove("dts-lightbox-stage--fill");
    }
    var c = document.getElementById("dtsLightboxCounter");
    var n = __dtsLightboxState.urls.length;
    var i = __dtsLightboxState.index;
    var multi = n > 1;
    var mode = __dtsLightboxState.fitFill ? "Fill" : "Fit";
    if (!c) return;
    c.textContent = multi ? i + 1 + " / " + n + " · " + mode : mode;
  }

  function toggleLightboxFitFill() {
    __dtsLightboxState.fitFill = !__dtsLightboxState.fitFill;
    syncLightboxFitFillUi();
  }

  function updateLightboxView() {
    var img = document.getElementById("dtsLightboxImg");
    var prev = document.getElementById("dtsLightboxPrev");
    var next = document.getElementById("dtsLightboxNext");
    var n = __dtsLightboxState.urls.length;
    var i = __dtsLightboxState.index;
    img.src = __dtsLightboxState.urls[i];
    img.alt = "Image " + (i + 1) + " of " + n;
    var multi = n > 1;
    prev.hidden = !multi;
    next.hidden = !multi;
    prev.setAttribute("aria-hidden", multi ? "false" : "true");
    next.setAttribute("aria-hidden", multi ? "false" : "true");
    syncLightboxFitFillUi();
  }

  function stepLightbox(delta) {
    var n = __dtsLightboxState.urls.length;
    if (n <= 1) return;
    __dtsLightboxState.index = (__dtsLightboxState.index + delta + n) % n;
    updateLightboxView();
  }

  function closeImageLightbox() {
    var box = document.getElementById("dtsLightbox");
    if (!box || !box.open) return;
    if (typeof box.close === "function") box.close();
  }

  function openImageLightbox(urls, startIndex) {
    if (!urls || !urls.length) return;
    var clean = [];
    for (var k = 0; k < urls.length; k++) {
      if (urls[k]) clean.push(urls[k]);
    }
    if (!clean.length) return;
    var box = document.getElementById("dtsLightbox");
    __dtsLightboxState.fitFill = false;
    __dtsLightboxState.urls = clean;
    var si = typeof startIndex === "number" && !isNaN(startIndex) ? startIndex | 0 : 0;
    __dtsLightboxState.index = Math.max(0, Math.min(si, clean.length - 1));
    updateLightboxView();
    if (typeof box.showModal === "function") box.showModal();
    if (__dtsLightboxState.onKey) {
      document.removeEventListener("keydown", __dtsLightboxState.onKey, true);
    }
    __dtsLightboxState.onKey = function (ev) {
      if (ev.key === "ArrowLeft") {
        ev.preventDefault();
        stepLightbox(-1);
      } else if (ev.key === "ArrowRight") {
        ev.preventDefault();
        stepLightbox(1);
      } else if (ev.key === "f" || ev.key === "F") {
        ev.preventDefault();
        toggleLightboxFitFill();
      }
    };
    document.addEventListener("keydown", __dtsLightboxState.onKey, true);
    document.getElementById("dtsLightboxClose").focus();
  }

  (function setupImageLightbox() {
    var box = document.getElementById("dtsLightbox");
    if (!box) return;
    box.addEventListener("close", function () {
      var img = document.getElementById("dtsLightboxImg");
      if (img) img.removeAttribute("src");
      if (__dtsLightboxState.onKey) {
        document.removeEventListener("keydown", __dtsLightboxState.onKey, true);
        __dtsLightboxState.onKey = null;
      }
      __dtsLightboxState.urls = [];
      __dtsLightboxState.touchX = null;
      __dtsLightboxState.fitFill = false;
      var st = document.getElementById("dtsLightboxStage");
      if (st) st.classList.remove("dts-lightbox-stage--fill");
    });
    document.getElementById("dtsLightboxClose").addEventListener("click", function (e) {
      e.stopPropagation();
      closeImageLightbox();
    });
    document.getElementById("dtsLightboxPrev").addEventListener("click", function (e) {
      e.stopPropagation();
      stepLightbox(-1);
    });
    document.getElementById("dtsLightboxNext").addEventListener("click", function (e) {
      e.stopPropagation();
      stepLightbox(1);
    });
    box.addEventListener(
      "touchstart",
      function (e) {
        if (e.touches && e.touches[0]) __dtsLightboxState.touchX = e.touches[0].clientX;
      },
      { passive: true },
    );
    box.addEventListener(
      "touchend",
      function (e) {
        var start = __dtsLightboxState.touchX;
        __dtsLightboxState.touchX = null;
        if (start === null || !e.changedTouches || !e.changedTouches[0]) return;
        var dx = e.changedTouches[0].clientX - start;
        if (Math.abs(dx) < 44) return;
        if (dx > 0) stepLightbox(-1);
        else stepLightbox(1);
      },
      { passive: true },
    );

    document.getElementById("results").addEventListener("click", function (ev) {
      var t = ev.target;
      if (!t || t.tagName !== "IMG") return;
      var list = document.querySelectorAll("#results .result-slot img");
      if (!list.length) return;
      var urls = [];
      var idx = 0;
      for (var i = 0; i < list.length; i++) {
        urls.push(list[i].src);
        if (list[i] === t) idx = i;
      }
      ev.preventDefault();
      openImageLightbox(urls, idx);
    });

    var historyRoot = document.getElementById("historyList");
    if (historyRoot) {
      historyRoot.addEventListener("click", function (ev) {
        var t = ev.target;
        if (!t || t.tagName !== "IMG") return;
        var thumbs = t.closest(".history-thumbs");
        if (!thumbs) return;
        var imgs = thumbs.querySelectorAll("img");
        var urls = [];
        var idx = 0;
        for (var j = 0; j < imgs.length; j++) {
          urls.push(imgs[j].src);
          if (imgs[j] === t) idx = j;
        }
        ev.preventDefault();
        openImageLightbox(urls, idx);
      });
    }
  })();

  (function setupHistoryDialog() {
    var dlg = document.getElementById("historyDialog");
    var openBtn = document.getElementById("btnOpenHistory");
    var closeBtn = document.getElementById("btnCloseHistory");
    var clearBtn = document.getElementById("btnClearHistory");
    openBtn.addEventListener("click", async function () {
      await migrateLegacyHistoryToServer();
      await renderHistoryList();
      dlg.removeAttribute("inert");
      if (typeof dlg.showModal === "function") dlg.showModal();
      openBtn.setAttribute("aria-expanded", "true");
    });
    closeBtn.addEventListener("click", function () { dlg.close(); });
    clearBtn.addEventListener("click", async function () {
      if (!window.confirm("Remove all saved generations from this browser?")) return;
      await fetch("/api/history", { method: "DELETE", headers: authHeaders() });
      try {
        localStorage.removeItem(HISTORY_KEY);
      } catch (e) {}
      await renderHistoryList();
    });
    dlg.addEventListener("close", function () {
      dlg.setAttribute("inert", "");
      openBtn.setAttribute("aria-expanded", "false");
      openBtn.focus();
    });
  })();

  document.getElementById("prompt").addEventListener("keydown", function (e) {
    if (e.key !== "Enter") return;
    if (!(e.metaKey || e.ctrlKey)) return;
    e.preventDefault();
    runComposerAction();
  });

  (function setupDialog() {
    const dlg = document.getElementById("toolsDialog");
    const openBtn = document.getElementById("btnOpenSetup");
    const closeBtn = document.getElementById("btnCloseSetup");
    openBtn.addEventListener("click", function () {
      dlg.removeAttribute("inert");
      if (typeof dlg.showModal === "function")
        dlg.showModal();
      openBtn.setAttribute("aria-expanded", "true");
    });
    closeBtn.addEventListener("click", function () {
      dlg.close();
    });
    dlg.addEventListener("close", function () {
      dlg.setAttribute("inert", "");
      openBtn.setAttribute("aria-expanded", "false");
      openBtn.focus();
    });
  })();

  window.addEventListener("pagehide", function (e) {
    if (!e.persisted) revokeResultBlobUrls();
  });

  document.getElementById("btnCheck").addEventListener("click", refreshStatus);
  document.getElementById("profile").addEventListener("change", updateComposerMode);
  document.getElementById("profileCustom").addEventListener("input", updateComposerMode);
  document.getElementById("btnGen").addEventListener("click", runComposerAction);
  document.getElementById("btnStop").addEventListener("click", function () {
    requestGenerationCancel();
    if (generateAbortController) generateAbortController.abort();
  });
  async function loadWebLogPath() {
    var pathEl = document.getElementById("webLogFilePath");
    var cmdEl = document.getElementById("webLogTailCmd");
    if (!pathEl || !cmdEl) return;
    try {
      var r = await fetch("/api/health");
      if (!r.ok) return;
      var j = await r.json();
      if (j.log_file) pathEl.textContent = j.log_file;
      if (j.tail_cli) cmdEl.textContent = j.tail_cli;
    } catch (e) {
      console.warn("loadWebLogPath:", e);
    }
  }

  loadWebLogPath();
  loadConfigs().then(function () { refreshStatus(); });
  </script>
</body>
</html>
