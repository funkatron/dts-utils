  function updateLightboxView() {
    var img = document.getElementById("dtsLightboxImg");
    var prev = document.getElementById("dtsLightboxPrev");
    var next = document.getElementById("dtsLightboxNext");
    var item = currentLightboxItem();
    var n = __dtsLightboxState.items.length;
    var i = __dtsLightboxState.index;
    if (!img || !item) return;
    img.src = item.url;
    img.alt = "Image " + (i + 1) + " of " + n;
    var multi = n > 1;
    prev.hidden = !multi;
    next.hidden = !multi;
    prev.setAttribute("aria-hidden", multi ? "false" : "true");
    next.setAttribute("aria-hidden", multi ? "false" : "true");
    syncLightboxChrome();
