  function syncLightboxFitFillUi() {
    var stage = document.getElementById("dtsLightboxStage");
    if (stage) {
      if (__dtsLightboxState.fitFill) stage.classList.add("dts-lightbox-stage--fill");
      else stage.classList.remove("dts-lightbox-stage--fill");
    }
    var c = document.getElementById("dtsLightboxCounter");
    var n = __dtsLightboxState.items.length;
    var i = __dtsLightboxState.index;
