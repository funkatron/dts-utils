  function stepLightbox(delta) {
    var n = __dtsLightboxState.items.length;
    if (n <= 1) return;
    __dtsLightboxState.index = (__dtsLightboxState.index + delta + n) % n;
    updateLightboxView();
  }

  function closeImageLightbox() {
    var box = document.getElementById("dtsLightbox");
    if (!box || !box.open) return;
    if (typeof box.close === "function") box.close();
  }

  function lightboxItemFromSlot(wrap) {
    if (!wrap) return null;
    var img = wrap.querySelector("img");
    if (!img || !img.src) return null;
    var a = wrap.querySelector(".result-download");
    var downloadName = "generated.png";
    if (a && a.getAttribute("download")) downloadName = a.getAttribute("download");
    return {
      url: img.src,
      downloadName: downloadName,
      details: wrap._generationDetails || {},
    };
  }

  function collectLightboxItemsFromSlots(root) {
    var items = [];
    if (!root) return items;
    var slots = root.querySelectorAll(".result-slot");
    var i;
    for (i = 0; i < slots.length; i++) {
      var item = lightboxItemFromSlot(slots[i]);
      if (item) items.push(item);
    }
    return items;
  }

  function collectHistoryLightboxItems(historyRoot) {
    var items = [];
    if (!historyRoot) return items;
    var slots = historyRoot.querySelectorAll(".history-thumbs .result-slot");
    var i;
    for (i = 0; i < slots.length; i++) {
      var item = lightboxItemFromSlot(slots[i]);
      if (item) items.push(item);
    }
    return items;
  }

  function openImageLightbox(items, startIndex) {
    if (!items || !items.length) return;
    var clean = [];
    var k;
    for (k = 0; k < items.length; k++) {
      var raw = items[k];
      if (!raw) continue;
      if (typeof raw === "string") {
        if (raw) clean.push({ url: raw, downloadName: "generated.png", details: {} });
        continue;
      }
      if (raw.url) {
        clean.push({
          url: raw.url,
          downloadName: raw.downloadName || "generated.png",
          details: raw.details || {},
        });
      }
    }
    if (!clean.length) return;
    var box = document.getElementById("dtsLightbox");
    __dtsLightboxState.fitFill = false;
    __dtsLightboxState.items = clean;
    var si = typeof startIndex === "number" && !isNaN(startIndex) ? startIndex | 0 : 0;
    __dtsLightboxState.index = Math.max(0, Math.min(si, clean.length - 1));
    updateLightboxView();
    if (typeof box.showModal === "function") box.showModal();
    if (__dtsLightboxState.onKey) {
      document.removeEventListener("keydown", __dtsLightboxState.onKey, true);
    }
    __dtsLightboxState.onKey = function (ev) {
      if (lightboxTypingTarget(ev.target)) return;
      if (ev.key === "ArrowLeft") {
        ev.preventDefault();
        stepLightbox(-1);
      } else if (ev.key === "ArrowRight") {
        ev.preventDefault();
        stepLightbox(1);
      } else if (ev.key === "f" || ev.key === "F") {
        ev.preventDefault();
        toggleLightboxFitFill();
      } else if (ev.key === "i" || ev.key === "I") {
        ev.preventDefault();
        toggleLightboxGenerationInfo();
      }
    };
    document.addEventListener("keydown", __dtsLightboxState.onKey, true);
    document.getElementById("dtsLightboxClose").focus();
  }

  (function setupImageLightbox() {
    var box = document.getElementById("dtsLightbox");
    if (!box) return;
    box.addEventListener("close", function () {
      var img = document.getElementById("dtsLightboxImg");
      if (img) img.removeAttribute("src");
      if (__dtsLightboxState.onKey) {
        document.removeEventListener("keydown", __dtsLightboxState.onKey, true);
        __dtsLightboxState.onKey = null;
      }
      __dtsLightboxState.items = [];
      __dtsLightboxState.touchX = null;
      __dtsLightboxState.fitFill = false;
      var st = document.getElementById("dtsLightboxStage");
      if (st) {
        st.classList.remove("dts-lightbox-stage--fill");
        st.scrollLeft = 0;
        st.scrollTop = 0;
      }
      var dl = document.getElementById("dtsLightboxDownload");
      if (dl) {
        dl.href = "#";
        dl.download = "generated.png";
      }
    });
    document.getElementById("dtsLightboxClose").addEventListener("click", function (e) {
      e.stopPropagation();
      closeImageLightbox();
    });
    var dlBtn = document.getElementById("dtsLightboxDownload");
    if (dlBtn) {
      dlBtn.addEventListener("click", function (e) {
        e.stopPropagation();
        if (dlBtn.hidden || dlBtn.getAttribute("href") === "#") {
          e.preventDefault();
        }
      });
    }
    var infoBtn = document.getElementById("dtsLightboxInfo");
    if (infoBtn) {
      infoBtn.addEventListener("click", function (e) {
        e.preventDefault();
        e.stopPropagation();
        showLightboxGenerationInfo();
      });
    }
    document.getElementById("dtsLightboxPrev").addEventListener("click", function (e) {
      e.stopPropagation();
      stepLightbox(-1);
    });
    document.getElementById("dtsLightboxNext").addEventListener("click", function (e) {
      e.stopPropagation();
      stepLightbox(1);
    });
    box.addEventListener(
      "touchstart",
      function (e) {
        if (__dtsLightboxState.fitFill) return;
        if (e.touches && e.touches[0]) __dtsLightboxState.touchX = e.touches[0].clientX;
      },
      { passive: true },
    );
    box.addEventListener(
      "touchend",
      function (e) {
        if (__dtsLightboxState.fitFill) {
          __dtsLightboxState.touchX = null;
          return;
        }
        var start = __dtsLightboxState.touchX;
        __dtsLightboxState.touchX = null;
        if (start === null || !e.changedTouches || !e.changedTouches[0]) return;
        var dx = e.changedTouches[0].clientX - start;
        if (Math.abs(dx) < 44) return;
        if (dx > 0) stepLightbox(-1);
        else stepLightbox(1);
      },
      { passive: true },
    );

    document.getElementById("results").addEventListener("click", function (ev) {
      var t = ev.target;
      if (!t || t.tagName !== "IMG") return;
      var slot = t.closest(".result-slot");
      if (!slot) return;
      var items = collectLightboxItemsFromSlots(document.getElementById("results"));
      if (!items.length) return;
      var idx = 0;
      var i;
      for (i = 0; i < items.length; i++) {
        if (items[i].url === t.src) {
          idx = i;
          break;
        }
      }
      ev.preventDefault();
      openImageLightbox(items, idx);
    });

    var historyRoot = document.getElementById("historyList");
    if (historyRoot) {
      historyRoot.addEventListener("click", function (ev) {
        var t = ev.target;
        if (!t || t.tagName !== "IMG") return;
        if (!t.closest(".history-thumbs")) return;
        var items = collectHistoryLightboxItems(historyRoot);
        if (!items.length) return;
        var idx = 0;
        var i;
        for (i = 0; i < items.length; i++) {
          if (items[i].url === t.src) {
            idx = i;
            break;
          }
        }
        ev.preventDefault();
        openImageLightbox(items, idx);
      });
    }
  })();

  (function setupHistoryDialog() {
    var dlg = document.getElementById("historyDialog");
    var openBtn = document.getElementById("btnOpenHistory");
    var closeBtn = document.getElementById("btnCloseHistory");
    var clearBtn = document.getElementById("btnClearHistory");
    openBtn.addEventListener("click", async function () {
      await migrateLegacyHistoryToServer();
      await renderHistoryList();
      var scroller = dlg.querySelector(".history-dialog-inner");
      if (scroller) scroller.scrollTop = 0;
      dlg.removeAttribute("inert");
      if (typeof dlg.showModal === "function") dlg.showModal();
      openBtn.setAttribute("aria-expanded", "true");
    });
    closeBtn.addEventListener("click", function () { dlg.close(); });
    clearBtn.addEventListener("click", async function () {
      if (!window.confirm("Remove all saved generations from this browser?")) return;
      await fetch("/api/history", { method: "DELETE", headers: authHeaders() });
      try {
        localStorage.removeItem(HISTORY_KEY);
      } catch (e) {}
      await renderHistoryList();
    });
    dlg.addEventListener("close", function () {
      dlg.setAttribute("inert", "");
      openBtn.setAttribute("aria-expanded", "false");
      openBtn.focus();
    });
  })();

  document.getElementById("prompt").addEventListener("keydown", function (e) {
    if (e.key !== "Enter") return;
    if (!(e.metaKey || e.ctrlKey)) return;
    e.preventDefault();
    runComposerAction();
  });

  (function setupDialog() {
    const dlg = document.getElementById("toolsDialog");
    const openBtn = document.getElementById("btnOpenSetup");
    const closeBtn = document.getElementById("btnCloseSetup");
    openBtn.addEventListener("click", function () {
      dlg.removeAttribute("inert");
      if (typeof dlg.showModal === "function")
        dlg.showModal();
      openBtn.setAttribute("aria-expanded", "true");
    });
    closeBtn.addEventListener("click", function () {
      dlg.close();
    });
    dlg.addEventListener("close", function () {
      dlg.setAttribute("inert", "");
      openBtn.setAttribute("aria-expanded", "false");
      openBtn.focus();
    });
  })();

  window.addEventListener("pagehide", function (e) {
    if (!e.persisted) {
      revokeResultBlobUrls();
      revokeInputImageObjectUrls();
    }
  });

  document.getElementById("btnCheck").addEventListener("click", refreshStatus);
  document.getElementById("outputModeImage").addEventListener("change", onOutputModeChange);
  document.getElementById("outputModeVideo").addEventListener("change", onOutputModeChange);
  document.getElementById("profile").addEventListener("change", function () {
    document.getElementById("profileCustom").value = "";
    trackRecentProfile(document.getElementById("profile").value);
    updateComposerMode();
  });
  document.getElementById("profileCustom").addEventListener("input", updateComposerMode);
  (function initInputImagesUi() {
    var inputEl = document.getElementById("inputImages");
    var dropzone = document.getElementById("inputImagesDropzone");
    var clearBtn = document.getElementById("btnClearInputImages");
    if (!inputEl || !dropzone) return;

    function ingestFileList(fileList) {
      if (!fileList || !fileList.length) return;
      mergeInputImageFiles(Array.from(fileList));
      renderInputImagesThumbs();
      syncInputImagesUi();
      resetInputImagesFileInput();
    }

    dropzone.addEventListener("click", function () {
      inputEl.click();
    });
    dropzone.addEventListener("keydown", function (ev) {
      if (ev.key === "Enter" || ev.key === " ") {
        ev.preventDefault();
        inputEl.click();
      }
    });
    inputEl.addEventListener("change", function (ev) {
      ingestFileList(ev.target.files);
    });
    if (clearBtn) {
      clearBtn.addEventListener("click", function (ev) {
        ev.preventDefault();
        clearInputImages();
      });
    }

    ["dragenter", "dragover"].forEach(function (type) {
      dropzone.addEventListener(type, function (ev) {
        ev.preventDefault();
        dropzone.classList.add("is-dragover");
      });
    });
    ["dragleave", "drop"].forEach(function (type) {
      dropzone.addEventListener(type, function (ev) {
        ev.preventDefault();
        if (type === "drop") ingestFileList(ev.dataTransfer && ev.dataTransfer.files);
        dropzone.classList.remove("is-dragover");
      });
    });
  })();
  document.getElementById("btnGen").addEventListener("click", runComposerAction);
  document.getElementById("btnStop").addEventListener("click", function () {
    requestGenerationCancel();
    if (generateAbortController) generateAbortController.abort();
  });
  async function loadWebLogPath() {
    var pathEl = document.getElementById("webLogFilePath");
    var cmdEl = document.getElementById("webLogTailCmd");
    if (!pathEl || !cmdEl) return;
    try {
      var r = await fetch("/api/health");
      if (!r.ok) return;
      var j = await r.json();
      if (j.log_file) pathEl.textContent = j.log_file;
      if (j.tail_cli) cmdEl.textContent = j.tail_cli;
    } catch (e) {
      console.warn("loadWebLogPath:", e);
    }
  }

  loadWebLogPath();
  loadConfigs().then(function () { refreshStatus(); });
